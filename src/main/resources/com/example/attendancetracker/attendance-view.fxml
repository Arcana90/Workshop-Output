<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500.0" prefWidth="720.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.attendancetracker.controller.AttendanceController">
    <children>
        <TableView fx:id="attendanceTable" layoutX="255.0" layoutY="31.0" prefHeight="438.0" prefWidth="434.0">
            <columns>
                <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                <TableColumn fx:id="colName" prefWidth="150.0" text="Student Name" />
                <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status" />
                <TableColumn fx:id="colDate" prefWidth="132.0" text="Date" />
            </columns>
        </TableView>

        <VBox layoutX="24.0" layoutY="31.0" prefHeight="438.0" prefWidth="205.0" spacing="15.0">
            <children>
                <Label text="Attendance Tracker Panel">
                    <font><Font name="System Bold" size="14.0" /></font>
                </Label>
                <Separator prefWidth="200.0" />

                <Label text="Student Name:" />
                <TextField fx:id="nameField" promptText="Enter Student Name" />

                <Label text="Attendance Status:" />
                <ComboBox fx:id="statusComboBox" prefWidth="205.0" promptText="Select Status" />

                <Label text="Record Date:" />
                <DatePicker fx:id="datePicker" prefWidth="205.0" />

                <Separator prefWidth="200.0" />
                <Button mnemonicParsing="false" onAction="#handleSave" prefWidth="205.0" style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-weight: bold;" text="Save Entry" />
                <Button mnemonicParsing="false" onAction="#handleDelete" prefWidth="205.0" style="-fx-background-color: #c62828; -fx-text-fill: white; -fx-font-weight: bold;" text="Delete Entry" />
            </children>
        </VBox>
    </children>
</AnchorPane>